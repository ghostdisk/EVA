{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
			"cacheVariables": {
				"CMAKE_C_COMPILER": "clang.exe",
				"CMAKE_CXX_COMPILER": "clang++.exe",
				"CMAKE_RC_COMPILER": "llvm-rc.exe",
				        "CMAKE_EXPORT_COMPILE_COMMANDS": true
            }
        },
        {
            "name": "x64-debug",
            "displayName": "x64 Debug",
            "inherits": "windows-base",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "x64-release",
            "displayName": "x64 Release",
            "inherits": "x64-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "$env{VSINSTALLDIR}Common7/IDE/CommonExtensions/Microsoft/CMake/cmake/Microsoft/SegmentHeap.cmake"
            }
        },
        {
            "name": "msvc-msbuild-debug",
            "displayName": "x64 MSVC MSBuild Debug",
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/build/msvc-msbuild-debug",
            "architecture": "x64"
        }
    ]
}
